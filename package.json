{
  "name": "tblog",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "node scripts/generate-migrations-manifest.mjs && nuxt dev",
    "build": "node scripts/generate-migrations-manifest.mjs && nuxt build && nuxt prepare",
    "preview": "wrangler dev --config wrangler.local.jsonc",
    "deploy": "wrangler deploy",
    "generate:migrations": "node scripts/generate-migrations-manifest.mjs",
    "types:cloudflare": "node scripts/cloudflare-types.mjs",
    "types:cloudflare:check": "node scripts/cloudflare-types.mjs --check",
    "postinstall": "nuxt prepare && node scripts/generate-migrations-manifest.mjs",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:check": "drizzle-kit check",
    "drizzle:migrate:local": "wrangler d1 migrations apply DB --local --config wrangler.local.jsonc",
    "drizzle:migrate:remote": "wrangler d1 migrations apply DB --remote --config wrangler.jsonc",
    "smoke:local": "node scripts/smoke-local.mjs",
    "typecheck": "node scripts/generate-migrations-manifest.mjs && pnpm types:cloudflare:check && nuxt typecheck",
    "test": "node scripts/generate-migrations-manifest.mjs && vitest run",
    "test:watch": "node scripts/generate-migrations-manifest.mjs && vitest"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "github-slugger": "^2.0.0",
    "h3": "1.15.11",
    "ipaddr.js": "^2.4.0",
    "mdast-util-to-string": "^4.0.0",
    "nuxt": "3.21.7",
    "qrcode": "^1.5.4",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260626.1",
    "@nuxt/test-utils": "^3.19.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.8",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "better-sqlite3": "^12.11.1",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^18.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.10",
    "wrangler": "4.104.0"
  },
  "pnpm": {
    "overrides": {
      "@nuxt/cli": "3.25.1",
      "svgo": "4.0.2"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
