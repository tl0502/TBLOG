NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for admin sessions (Nuxt dev reads .env; Wrangler preview reads .dev.vars).
# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
# Or run: node scripts/ensure-local-secrets.mjs
# SESSION_SECRET must be ≥32 random bytes (base64url). Placeholder strings are rejected at runtime.
SESSION_SECRET=
AUTH_ENCRYPTION_KEY=

# ANALYTICS_REPORT_TOKEN=<optional-third-party-report-api-token>
# UMAMI_API_TOKEN=<optional-umami-cloud-api-key>
# UMAMI_SELF_HOSTED_CREDENTIAL={"apiBaseUrl":"https://umami.example.com/api","token":"<self-hosted-bearer-token>"}
# PLAUSIBLE_API_KEY=<optional-plausible-stats-api-key>
# ALGOLIA_ADMIN_KEY=<optional-algolia-admin-api-key-for-search-management>
# OPENAI_API_KEY=<optional-openai-api-key-for-comment-moderation>

# D1 is provided through the Wrangler DB binding in wrangler.jsonc.
